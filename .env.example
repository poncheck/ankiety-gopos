GOPOS_CLIENT_ID=your_client_id_here
GOPOS_CLIENT_SECRET=your_client_secret_here
GOPOS_ORGANIZATION_ID=your_organization_id_here
GOPOS_BASE_URL=https://app.gopos.io

DATABASE_URL=postgresql+asyncpg://ankiety:ankiety@db:5432/ankiety
SECRET_KEY=change-me-to-random-secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# Domena serwera (wymagane gdy Vite zgłasza "Blocked request")
ALLOWED_HOST=twoja-domena.pl

# SMTP — wysyłanie kodów rabatowych po wypełnieniu ankiety (opcjonalne)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=noreply@example.com
SMTP_PASSWORD=haslo_smtp
SMTP_FROM=Ankiety <noreply@example.com>
SMTP_TLS=true
